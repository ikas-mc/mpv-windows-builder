diff --git a/src/file/dirs_uwp.cpp b/src/file/dirs_uwp.cpp
new file mode 100644
index 00000000..d9ef911b
--- /dev/null
+++ b/src/file/dirs_uwp.cpp
@@ -0,0 +1,88 @@
+/*
+ * This file is part of libbluray
+ * Copyright (C) 2011  VideoLAN
+ *
+ * This library is free software; you can redistribute it and/or
+ * modify it under the terms of the GNU Lesser General Public
+ * License as published by the Free Software Foundation; either
+ * version 2.1 of the License, or (at your option) any later version.
+ *
+ * This library is distributed in the hope that it will be useful,
+ * but WITHOUT ANY WARRANTY; without even the implied warranty of
+ * MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the GNU
+ * Lesser General Public License for more details.
+ *
+ * You should have received a copy of the GNU Lesser General Public
+ * License along with this library. If not, see
+ * <http://www.gnu.org/licenses/>.
+ */
+
+#ifdef HAVE_CONFIG_H
+# include "config.h"
+#endif
+
+#include <windows.h>
+
+#ifdef inline
+#undef inline
+#endif
+
+#include <winrt/Windows.ApplicationModel.h>
+#include <winrt/Windows.Storage.h>
+
+static char *utf8_from_wide(const wchar_t *path)
+{
+    int len = WideCharToMultiByte(CP_UTF8, 0, path, -1, NULL, 0, NULL, NULL);
+    char *result = (char *)malloc(len);
+    if (result) {
+        WideCharToMultiByte(CP_UTF8, 0, path, -1, result, len, NULL, NULL);
+    }
+    return result;
+}
+
+extern "C"
+{
+#include "dirs.h"
+
+    char *win32_get_font_dir(const char *font_file)
+    {
+        return NULL;
+    }
+
+    char *file_get_config_home(void)
+    {
+        return file_get_data_home();
+    }
+
+    char *file_get_data_home(void)
+    {
+        auto localFolder = winrt::Windows::Storage::ApplicationData::Current().LocalFolder();
+        return utf8_from_wide(localFolder.Path().c_str());
+    }
+
+    char *file_get_cache_home(void)
+    {
+        return file_get_data_home();
+    }
+
+    const char *file_get_config_system(const char *dir)
+    {
+        if (!dir) // first call
+            return file_get_data_home();
+
+        return NULL; // next call
+    }
+
+    char *file_get_install_dir(void)
+    {
+        try
+        {
+            auto path = winrt::Windows::ApplicationModel::Package::Current().InstalledLocation().Path();
+            return utf8_from_wide(path.c_str());
+        }
+        catch (...)
+        {
+            return NULL;
+        }
+    }
+}
\ No newline at end of file
